    "S3Q3": {
      "id": "S3Q3", "section": "S3", "type": "card_select",
      "text": "Which work environment suits you best?", "field": "work_environment",
      "options": [
        { "value": "remote", "label": "🏠 Remote" },
        { "value": "office", "label": "🏢 Office" },
        { "value": "hybrid", "label": "🔄 Hybrid" },
        { "value": "flexible", "label": "✨ Flexible" }
